{
  "name": "pokopia-house-planner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build:serebii-favorites": "npx tsx scripts/build-serebii-favorite-map.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "vercel:pull:preview": "vercel pull --yes --environment=preview",
    "vercel:pull:prod": "vercel pull --yes --environment=production",
    "vercel:build": "vercel build",
    "vercel:build:prod": "vercel build --prod",
    "vercel:deploy": "vercel deploy --prebuilt",
    "vercel:deploy:prod": "vercel deploy --prebuilt --prod",
    "deploy:preview": "vercel pull --yes --environment=preview && vercel build && vercel deploy --prebuilt",
    "deploy:prod": "vercel pull --yes --environment=production && vercel build --prod && vercel deploy --prebuilt --prod"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
